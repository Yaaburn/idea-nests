# ═══════════════════════════════════════════════
# TalentNet Environment Variables
# ═══════════════════════════════════════════════

# ─── Backend Connector Gateway ───
# Get these from Google Cloud Console → APIs & Services → Credentials
# Required: Enable Google Sheets API

# OAuth 2.0 Client ID (Web application type)
GOOGLE_CLIENT_ID=your_google_client_id_here

# OAuth 2.0 Client Secret (BACKEND ONLY — never expose to browser)
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth redirect URI (must match Google Console config)
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Service Account email (for TalentNet Bot mode)
# Create a service account in Google Cloud Console → IAM → Service Accounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=talentnet-bot@your-project.iam.gserviceaccount.com

# Service Account private key (from JSON key file, keep quotes, use \n for newlines)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── MongoDB ───
MONGODB_URI=mongodb://localhost:27017/talentnet

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# Server port
PORT=3001

# ─── Frontend (Vite) ───
# API key is OPTIONAL and demo-only. Not required for production.
# VITE_GOOGLE_API_KEY=your_api_key_here

# Backend connector URL
VITE_BACKEND_URL=http://localhost:3001

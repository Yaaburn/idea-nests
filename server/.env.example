DATABASE_URL="postgresql://user:password@localhost:5432/idea_nests?schema=public"
REDIS_URL="redis://localhost:6379"

# Google Service Account (Share-to-Bot)
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Google OAuth (Calendar)
GOOGLE_OAUTH_CLIENT_ID="your-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="your-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"

# App
PORT=3001
NODE_ENV=development
SECRETS_ENCRYPTION_KEY="replace-with-32-char-random-string-for-security"
RAW_RECORD_RETENTION_DAYS=90
